# ─── Gemini AI ───────────────────────────────────────────────────────────────
# Required for AI listing optimization in Owner dashboard
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Required for payment processing (Deposit & Rent payments)
# Get yours at: https://dashboard.stripe.com/apikeys
# Secret key — server-side only, NEVER expose in frontend
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
# Publishable key — safe for frontend (VITE_ prefix auto-exposes via Vite)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# ─── Mapbox ──────────────────────────────────────────────────────────────────
# Required for the map view. Must be a PUBLIC token starting with 'pk.'
# Get yours at: https://account.mapbox.com/access-tokens/
VITE_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token_here

# ─── Google Maps ─────────────────────────────────────────────────────────────
# Optional — used for neighbourhood page / geocoding
# Get yours at: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─── App URL ─────────────────────────────────────────────────────────────────
# The public URL of your deployed app (used for Stripe redirect URLs)
# Local: http://localhost:3000
# Render: https://your-app-name.onrender.com
# Vercel: https://your-app-name.vercel.app
APP_URL=http://localhost:3000

# ─── Server ──────────────────────────────────────────────────────────────────
# Port is set automatically by Render/Vercel. Only needed for local dev.
PORT=3000
NODE_ENV=development
